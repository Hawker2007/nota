{
  "identifier": "default",
  "description": "Default permissions for nota",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": ["$DOCUMENT/Nota/**", "$DOCUMENT/Nota"]
    },
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "core:window:allow-is-visible",
    "shell:allow-open",
    "notification:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
